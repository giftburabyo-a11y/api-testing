<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="REST Assured API Test Suite" verbose="2" parallel="none">
    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>
    <test name="GET Request Tests">
        <classes>
            <class name="com.apitest.tests.GetRequestTests"/>
        </classes>
    </test>
    <test name="POST Request Tests">
        <classes>
            <class name="com.apitest.tests.PostRequestTests"/>
        </classes>
    </test>
    <test name="PUT Request Tests">
        <classes>
            <class name="com.apitest.tests.PutRequestTests"/>
        </classes>
    </test>
    <test name="DELETE Request Tests">
        <classes>
            <class name="com.apitest.tests.DeleteRequestTests"/>
        </classes>
    </test>
    <test name="User Endpoint Tests">
        <classes>
            <class name="com.apitest.tests.UserTests"/>
        </classes>
    </test>
    <test name="Negative Tests">
        <classes>
            <class name="com.apitest.tests.NegativeTests"/>
        </classes>
    </test>
</suite>